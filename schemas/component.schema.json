{
  "$defs": {
    "AttributeValue": {
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "key",
        "value"
      ],
      "title": "AttributeValue",
      "type": "object"
    },
    "ComponentType": {
      "enum": [
        "system",
        "subsystem",
        "assembly",
        "part",
        "software",
        "interface"
      ],
      "title": "ComponentType",
      "type": "string"
    },
    "MeasureKind": {
      "description": "OOSEM measure taxonomy: MOE (operational), MOP (system), TPM (component).",
      "enum": [
        "MOE",
        "MOP",
        "TPM"
      ],
      "title": "MeasureKind",
      "type": "string"
    },
    "Parameter": {
      "description": "A typed numeric quantity on a requirement or component.\n\nEither a literal `value`, or an `expr` deriving it from other parameters\n(`span * chord`, `GROS0001.mass - EMPT0001.mass`,\n`rollup('WING', 'mass')`). Unlike `attributes`, these participate in\nconstraint evaluation.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "unit": {
          "default": "",
          "title": "Unit",
          "type": "string"
        },
        "expr": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expr"
        },
        "kind": {
          "anyOf": [
            {
              "$ref": "#/$defs/MeasureKind"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name"
      ],
      "title": "Parameter",
      "type": "object"
    },
    "Relation": {
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "reviewed_fingerprint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewed Fingerprint"
        }
      },
      "required": [
        "type",
        "target"
      ],
      "title": "Relation",
      "type": "object"
    }
  },
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "name": {
      "default": "",
      "title": "Name",
      "type": "string"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "type": {
      "$ref": "#/$defs/ComponentType",
      "default": "assembly"
    },
    "parent": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent"
    },
    "part_number": {
      "default": "",
      "title": "Part Number",
      "type": "string"
    },
    "supplier": {
      "default": "",
      "title": "Supplier",
      "type": "string"
    },
    "quantity": {
      "default": 1,
      "title": "Quantity",
      "type": "integer"
    },
    "satisfies": {
      "items": {
        "type": "string"
      },
      "title": "Satisfies",
      "type": "array"
    },
    "verification_cases": {
      "items": {
        "type": "string"
      },
      "title": "Verification Cases",
      "type": "array"
    },
    "attributes": {
      "items": {
        "$ref": "#/$defs/AttributeValue"
      },
      "title": "Attributes",
      "type": "array"
    },
    "relations": {
      "items": {
        "$ref": "#/$defs/Relation"
      },
      "title": "Relations",
      "type": "array"
    },
    "parameters": {
      "items": {
        "$ref": "#/$defs/Parameter"
      },
      "title": "Parameters",
      "type": "array"
    },
    "created": {
      "title": "Created",
      "type": "string"
    },
    "modified": {
      "title": "Modified",
      "type": "string"
    }
  },
  "required": [
    "id"
  ],
  "title": "reqmesh component",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
