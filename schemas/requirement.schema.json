{
  "$defs": {
    "AttributeValue": {
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "key",
        "value"
      ],
      "title": "AttributeValue",
      "type": "object"
    },
    "Constraint": {
      "description": "A boolean expression over parameters that must hold.\n\n`assume` is an optional precondition: when present and not satisfied the\nconstraint is out of scope rather than failed (SysML assume/require).",
      "properties": {
        "expr": {
          "title": "Expr",
          "type": "string"
        },
        "assume": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assume"
        }
      },
      "required": [
        "expr"
      ],
      "title": "Constraint",
      "type": "object"
    },
    "Parameter": {
      "description": "A typed numeric quantity on a requirement or component.\n\nEither a literal `value`, or an `expr` deriving it from other parameters\n(`span * chord`, `GROS0001.mass - EMPT0001.mass`,\n`rollup('WING', 'mass')`). Unlike `attributes`, these participate in\nconstraint evaluation.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "unit": {
          "default": "",
          "title": "Unit",
          "type": "string"
        },
        "expr": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expr"
        }
      },
      "required": [
        "name"
      ],
      "title": "Parameter",
      "type": "object"
    },
    "Priority": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Priority",
      "type": "string"
    },
    "Reference": {
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "keyword": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Keyword"
        },
        "kind": {
          "default": "impl",
          "title": "Kind",
          "type": "string"
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        },
        "lines": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lines"
        }
      },
      "required": [
        "path"
      ],
      "title": "Reference",
      "type": "object"
    },
    "Relation": {
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "reviewed_fingerprint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewed Fingerprint"
        }
      },
      "required": [
        "type",
        "target"
      ],
      "title": "Relation",
      "type": "object"
    },
    "RequirementStatus": {
      "enum": [
        "proposed",
        "approved",
        "implemented",
        "verified",
        "rejected",
        "deprecated"
      ],
      "title": "RequirementStatus",
      "type": "string"
    },
    "RequirementType": {
      "enum": [
        "functional",
        "non_functional",
        "interface",
        "design",
        "constraint"
      ],
      "title": "RequirementType",
      "type": "string"
    },
    "VerificationMethod": {
      "enum": [
        "test",
        "analysis",
        "demonstration",
        "inspection"
      ],
      "title": "VerificationMethod",
      "type": "string"
    }
  },
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "type": {
      "$ref": "#/$defs/RequirementType",
      "default": "functional"
    },
    "name": {
      "default": "",
      "title": "Name",
      "type": "string"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "priority": {
      "$ref": "#/$defs/Priority",
      "default": "medium"
    },
    "status": {
      "$ref": "#/$defs/RequirementStatus",
      "default": "proposed"
    },
    "verification_method": {
      "$ref": "#/$defs/VerificationMethod",
      "default": "test"
    },
    "attributes": {
      "items": {
        "$ref": "#/$defs/AttributeValue"
      },
      "title": "Attributes",
      "type": "array"
    },
    "parameters": {
      "items": {
        "$ref": "#/$defs/Parameter"
      },
      "title": "Parameters",
      "type": "array"
    },
    "constraints": {
      "items": {
        "$ref": "#/$defs/Constraint"
      },
      "title": "Constraints",
      "type": "array"
    },
    "relations": {
      "items": {
        "$ref": "#/$defs/Relation"
      },
      "title": "Relations",
      "type": "array"
    },
    "verification_cases": {
      "items": {
        "type": "string"
      },
      "title": "Verification Cases",
      "type": "array"
    },
    "verification_status": {
      "default": "pending",
      "title": "Verification Status",
      "type": "string"
    },
    "parent": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent"
    },
    "cascade_from": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cascade From"
    },
    "rationale": {
      "default": "",
      "title": "Rationale",
      "type": "string"
    },
    "source": {
      "default": "",
      "title": "Source",
      "type": "string"
    },
    "allocated_to": {
      "default": "",
      "title": "Allocated To",
      "type": "string"
    },
    "baseline": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Baseline"
    },
    "reviewed": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reviewed"
    },
    "derived": {
      "default": false,
      "title": "Derived",
      "type": "boolean"
    },
    "normative": {
      "default": true,
      "title": "Normative",
      "type": "boolean"
    },
    "effort": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Effort"
    },
    "priorities": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Priorities",
      "type": "object"
    },
    "needs": {
      "items": {
        "type": "string"
      },
      "title": "Needs",
      "type": "array"
    },
    "references": {
      "items": {
        "$ref": "#/$defs/Reference"
      },
      "title": "References",
      "type": "array"
    },
    "created": {
      "title": "Created",
      "type": "string"
    },
    "modified": {
      "title": "Modified",
      "type": "string"
    }
  },
  "required": [
    "id"
  ],
  "title": "reqmesh requirement",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
