{
  "$defs": {
    "CaseType": {
      "description": "OOSEM Activity 6: verification (did we build it right?) vs validation (did we build the right thing?).",
      "enum": [
        "verification",
        "validation"
      ],
      "title": "CaseType",
      "type": "string"
    },
    "ExecutionRecord": {
      "properties": {
        "timestamp": {
          "title": "Timestamp",
          "type": "string"
        },
        "status": {
          "default": "pending",
          "title": "Status",
          "type": "string"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "executed_by": {
          "default": "",
          "title": "Executed By",
          "type": "string"
        }
      },
      "title": "ExecutionRecord",
      "type": "object"
    },
    "Measurement": {
      "description": "A measured value recorded against a requirement parameter.\n\n`parameter` is a fully-qualified reference (`\"AFRM0005.max_load\"`). The\nevaluation engine substitutes these into the owning requirement's\nconstraints to compute a verification verdict from evidence rather than a\nhand-set status.",
      "properties": {
        "parameter": {
          "title": "Parameter",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        },
        "unit": {
          "default": "",
          "title": "Unit",
          "type": "string"
        }
      },
      "required": [
        "parameter",
        "value"
      ],
      "title": "Measurement",
      "type": "object"
    },
    "TestStep": {
      "properties": {
        "action": {
          "default": "",
          "title": "Action",
          "type": "string"
        },
        "expected_result": {
          "default": "",
          "title": "Expected Result",
          "type": "string"
        },
        "actual_result": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Actual Result"
        }
      },
      "title": "TestStep",
      "type": "object"
    }
  },
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "name": {
      "default": "",
      "title": "Name",
      "type": "string"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "method": {
      "default": "test",
      "title": "Method",
      "type": "string"
    },
    "status": {
      "default": "pending",
      "title": "Status",
      "type": "string"
    },
    "result": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Result"
    },
    "verified_requirements": {
      "items": {
        "type": "string"
      },
      "title": "Verified Requirements",
      "type": "array"
    },
    "test_procedure": {
      "default": "",
      "title": "Test Procedure",
      "type": "string"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/TestStep"
      },
      "title": "Steps",
      "type": "array"
    },
    "execution_history": {
      "items": {
        "$ref": "#/$defs/ExecutionRecord"
      },
      "title": "Execution History",
      "type": "array"
    },
    "measurements": {
      "items": {
        "$ref": "#/$defs/Measurement"
      },
      "title": "Measurements",
      "type": "array"
    },
    "case_type": {
      "$ref": "#/$defs/CaseType",
      "default": "verification"
    },
    "environment": {
      "default": "",
      "title": "Environment",
      "type": "string"
    },
    "decision_gate": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Decision Gate"
    },
    "created": {
      "title": "Created",
      "type": "string"
    },
    "modified": {
      "title": "Modified",
      "type": "string"
    }
  },
  "required": [
    "id"
  ],
  "title": "reqmesh verification_case",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
